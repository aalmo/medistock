# ─────────────────────────────────────────────────────────────────────────────
# MediStock — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — default, no setup needed)
DATABASE_URL="file:./prisma/prisma/dev.db"

# Production (PostgreSQL — Neon / Supabase / Railway / etc.)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-32-char-string"

# ── Cron Job Security ─────────────────────────────────────────────────────────
# Used as Bearer token for /api/cron/* endpoints
CRON_SECRET="replace-with-random-string"

# ── Email Alerts (SMTP) — optional ───────────────────────────────────────────
# Leave unset to use Ethereal in dev (preview URL logged to console)
SMTP_HOST="smtp.strato.de"
SMTP_PORT="587"
SMTP_USER="you@yourdomain.com"
SMTP_PASS="yourpassword"
EMAIL_FROM="MediStock <noreply@yourdomain.com>"
