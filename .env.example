# Environment Variables - Copy to .env.local and fill in values

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars-change-this"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Resend Email (https://resend.com - free tier available)
RESEND_API_KEY="re_xxxxxxxxxx"
RESEND_FROM_EMAIL="MediStock <noreply@yourdomain.com>"

# Cron Security
CRON_SECRET="your-cron-secret-key"

